{
    "name": "boa-intelligence/laravel-project-analyzer",
    "description": "Comprehensive static analysis and documentation engine for Laravel applications",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "static-analysis",
        "documentation",
        "code-quality",
        "architecture"
    ],
    "authors": [
        {
            "name": "BOA Intelligence",
            "email": "info@boa-intelligence.com"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "nikic/php-parser": "^4.15|^5.0",
        "phpstan/phpstan": "^1.10|^2.0",
        "symfony/finder": "^6.0|^7.0",
        "inertiajs/inertia-laravel": "^1.0|^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "ProjectAnalyzer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ProjectAnalyzer\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ProjectAnalyzer\\ProjectAnalyzerServiceProvider"
            ],
            "aliases": {
                "ProjectAnalyzer": "ProjectAnalyzer\\Facades\\Analyzer"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/pest --coverage",
        "test-coverage": "pest --coverage --min=85",
        "lint": "phpstan analyse src --level=5"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
